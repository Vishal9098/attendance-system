{
  "info": {
    "name": "AttendAI API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8000/api" },
    { "key": "TOKEN", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"employee\",\n  \"face_image\": \"data:image/jpeg;base64,/9j/...\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('TOKEN', data.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Punch In",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/attendance/punch-in",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"face_image\": \"data:image/jpeg;base64,/9j/...\",\n  \"latitude\": 28.6139,\n  \"longitude\": 77.2090\n}"
            }
          }
        },
        {
          "name": "Punch Out",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/attendance/punch-out",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"face_image\": \"data:image/jpeg;base64,/9j/...\",\n  \"latitude\": 28.6139,\n  \"longitude\": 77.2090\n}"
            }
          }
        },
        {
          "name": "Today Status",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/attendance/today",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "History",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/attendance/history",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "Overtime",
      "item": [
        {
          "name": "Request OT",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/overtime/request",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-05-07\",\n  \"reason\": \"Project deadline\",\n  \"expected_hours\": 2\n}"
            }
          }
        },
        {
          "name": "My OT Requests",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/overtime/my-requests",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Pending OT (Manager)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/overtime/pending",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Approve OT",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/overtime/OT_ID_HERE/action",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"remarks\": \"Approved for project deadline\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "All Users",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/admin/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/admin/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "All Attendance",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/admin/attendance?date=2025-05-07",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "AI Assistant",
      "item": [
        {
          "name": "Query AI",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/ai/query",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Who came late today?\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "My Report",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/reports/my-report",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Export Excel",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/reports/export/excel",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Export PDF",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/reports/export/pdf",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    }
  ]
}
